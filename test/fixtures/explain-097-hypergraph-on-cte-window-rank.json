  "query": "with `salary_rank` as (/* select#2 */ select `e`.`emp_no` AS `emp_no`,`e`.`first_name` AS `first_name`,`e`.`last_name` AS `last_name`,`d`.`dept_no` AS `dept_no`,`s`.`salary` AS `salary`,rank() OVER (PARTITION BY `d`.`dept_no` ORDER BY `hypergraph_test`.`s`.`salary` desc )  AS `dept_rank` from `hypergraph_test`.`employees` `e` join `hypergraph_test`.`dept_emp` `d` join `hypergraph_test`.`salaries` `s` where ((`s`.`to_date` = DATE'9999-01-01') and (`d`.`to_date` = DATE'9999-01-01') and multiple equal(`e`.`emp_no`, `s`.`emp_no`, `d`.`emp_no`))) /* select#1 */ select `salary_rank`.`emp_no` AS `emp_no`,`salary_rank`.`first_name` AS `first_name`,`salary_rank`.`last_name` AS `last_name`,`salary_rank`.`dept_no` AS `dept_no`,`salary_rank`.`salary` AS `salary`,`salary_rank`.`dept_rank` AS `dept_rank` from `salary_rank` where multiple equal(1, `salary_rank`.`dept_rank`)",
